# Data Collection and Preprocessing Environment Variables
# Copy this file to .env and fill in your API keys

# ===========================================
# AI Hub Configuration
# ===========================================
# Get your API key from https://aihub.or.kr (My Page after login)
AIHUB_API_KEY=your_aihub_api_key_here

# Path to aihubshell binary (download from AI Hub)
AIHUB_SHELL_PATH=./aihubshell

# Directory to store downloaded AI Hub datasets
AIHUB_DOWNLOAD_DIR=./data/raw/aihub

# ===========================================
# Seoul Open Data API Configuration
# ===========================================
# Get your API key from https://data.seoul.go.kr
SEOUL_API_KEY=your_seoul_api_key_here

# Directory to store Seoul API data
SEOUL_DOWNLOAD_DIR=./data/raw/seoul_api

# ===========================================
# Public Data Portal (data.go.kr) Configuration
# ===========================================
# Get your API key from https://www.data.go.kr
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# Directory to store data.go.kr data
DATA_GO_KR_DOWNLOAD_DIR=./data/raw/data_go_kr

# ===========================================
# General Settings
# ===========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===========================================
# Optional: HuggingFace Configuration
# ===========================================
# For downloading EXAONE model (if gated)
# HF_TOKEN=your_huggingface_token_here
