   "source": [
    "# 7. Run specific experiments only\n",
    "# Available IDs: EXP-002-rank8, EXP-002-rank32, EXP-002-rank64,\n",
    "#                EXP-003-lr1e4-cosine, EXP-003-lr5e5-cosine, EXP-003-lr2e4-linear,\n",
    "#                EXP-004-2epochs, EXP-004-3epochs\n",
    "\n",
    "EXP_IDS = [\"EXP-002-rank32\", \"EXP-003-lr1e4-cosine\"]  # modify as needed\n",
    "\n",
    "!python {PROJECT_ROOT}/src/training/run_experiments.py \\\n",
    "    --exp_ids {' '.join(EXP_IDS)}"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# 8. View experiment results summary\n",
    "import json\n",
    "\n",
    "results_path = f\"{PROJECT_ROOT}/docs/outputs/experiments/hparam_search_results.json\"\n",
    "if os.path.exists(results_path):\n",
    "    with open(results_path) as f:\n",
    "        data = json.load(f)\n",
    "\n",
    "    print(f\"Issue #67 Hyperparameter Search Results\")\n",
    "    print(f\"Baseline: BLEU={data['baseline']['bleu']}, ROUGE-L={data['baseline']['rouge_l']}\")\n",
    "    print(f\"Targets:  BLEU>={data['targets']['bleu']}, ROUGE-L>={data['targets']['rouge_l']}\")\n",
    "    print()\n",
    "\n",
    "    results = [r for r in data.get(\"results\", []) if \"bleu\" in r]\n",
    "    results.sort(key=lambda x: x[\"bleu\"] + x[\"rouge_l\"], reverse=True)\n",
    "\n",
    "    print(f\"{'Rank':<5} {'Exp ID':<28} {'BLEU':>8} {'ROUGE-L':>9} {'Status'}\")\n",
    "    print(\"-\" * 65)\n",
    "    for i, r in enumerate(results, 1):\n",
    "        status = \"BOTH PASS\" if r[\"bleu_target_met\"] and r[\"rouge_target_met\"] else \\\n",
    "                 \"PARTIAL\" if r[\"bleu_target_met\"] or r[\"rouge_target_met\"] else \"BELOW TARGET\"\n",
    "        print(f\"#{i:<4} {r['exp_id']:<28} {r['bleu']:>8.2f} {r['rouge_l']:>9.2f}  {status}\")\n",
    "\n",
    "    if data.get(\"best_config\"):\n",
    "        bc = data[\"best_config\"]\n",
    "        print(f\"\\nBest config: rank={bc['lora_r']}, lr={bc['lr']}, \"\n",
    "              f\"scheduler={bc['lr_scheduler']}, epochs={bc['epochs']}\")\n",
    "else:\n",
    "    print(\"No results yet. Run experiments first.\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# 9. (Optional) Upload best model to HuggingFace Hub\n",
    "# Only run if BLEU >= 30 and ROUGE-L >= 40\n",
    "\n",
    "HF_REPO_ID = \"GovOn-Org/exaone-civil-complaint-qlora\"  # update as needed\n",
    "\n",
    "if os.path.exists(results_path):\n",
    "    with open(results_path) as f:\n",
    "        data = json.load(f)\n",
    "\n",
    "    best_results = [r for r in data.get(\"results\", []) if \"bleu\" in r]\n",
    "    best_results.sort(key=lambda x: x[\"bleu\"] + x[\"rouge_l\"], reverse=True)\n",
    "\n",
    "    if best_results:\n",
    "        best = best_results[0]\n",
    "        if best[\"bleu_target_met\"] and best[\"rouge_target_met\"]:\n",
    "            from huggingface_hub import HfApi\n",
    "            api = HfApi()\n",
    "            checkpoint = os.path.join(best[\"checkpoint_dir\"], \"final\")\n",
    "            print(f\"Uploading {best['exp_id']} → {HF_REPO_ID}\")\n",
    "            api.upload_folder(\n",
    "                folder_path=checkpoint,\n",
    "                repo_id=HF_REPO_ID,\n",
    "                repo_type=\"model\",\n",
    "                commit_message=f\"Issue #67: Best QLoRA checkpoint ({best['exp_id']}) BLEU={best['bleu']:.2f} ROUGE-L={best['rouge_l']:.2f}\",\n",
    "            )\n",
    "            print(\"Upload complete.\")\n",
    "        else:\n",
    "            print(f\"Best model BLEU={best['bleu']:.2f} / ROUGE-L={best['rouge_l']:.2f} — targets not met, skipping upload.\")\n",
    "    else:\n",
    "        print(\"No successful experiments found.\")"
   ],
   "execution_count": null,
   "outputs": []
  }
